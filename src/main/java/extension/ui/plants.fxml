<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<TabPane maxHeight="Infinity" maxWidth="Infinity" prefHeight="430.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="extension.Plants">
   <tabs>
      <Tab text="Home">
         <content>
            <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="10.0">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
               <children>
                  <TextArea fx:id="commandsArea" editable="false" maxHeight="Infinity" maxWidth="Infinity" prefHeight="350.0" wrapText="true" style="-fx-font-size: 12px; -fx-font-family: monospace;" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </content>
      </Tab>
      <Tab text="Logs">
         <content>
            <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="10.0">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
               <children>
                  <TextArea fx:id="logArea" editable="false" maxHeight="Infinity" maxWidth="Infinity" prefHeight="340.0" wrapText="true" style="-fx-font-size: 11px; -fx-font-family: monospace;" VBox.vgrow="ALWAYS" />
                  <HBox spacing="10.0" maxWidth="Infinity" alignment="CENTER_LEFT">
                     <children>
                     <Label text="Log level:" />
                     <ComboBox fx:id="logLevelCombo" prefWidth="140.0" style="-fx-border-color:#000000; -fx-border-width:1; -fx-background-color:#ffffff; -fx-text-fill:#000000;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Clear logs" onAction="#clearLogs" maxWidth="Infinity" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </Tab>
   </tabs>
</TabPane>
