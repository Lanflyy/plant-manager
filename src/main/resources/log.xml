<configuration>
    <appender name="UI" class="extension.logging.UiLogAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>[%d{HH:mm:ss}] [%level] %msg%n</pattern>
        </layout>
    </appender>

    <logger name="extension" level="INFO" additivity="false">
        <appender-ref ref="UI" />
    </logger>

    <root level="OFF" />
</configuration>
